{
  // Json5 configuration : https://spec.json5.org
  // You can override values in config.json5 or config.json if you prefer.

  "screener": {
    // Configuration for the tool that takes screenshots.

    // Areas of less than 5 pixels triggers full-screen capture.
    "full_screen_capture_threshold": 5
  },

  "ocr": {
    // OCR configuration to extract text from the screen.
    "type": "easyocr",
    "download": true,
    "model_path": "models/easy_ocr",
    "langs": ["fr", "en"],

    /* Alternative : using a remote OCR
    "type": "remote",
    "url": "http://localhost:11111/ocr",
    */
  },

  "tts": {
    // TTS is the tool that transforms text to audio data.
    "type": "omnivoice",
    "model_path": "models/OmniVoice",
    "ref_voice_path": null,
    "ref_voice_text": null,
    "repo_id": "k2-fsa/OmniVoice",
    "device": "auto",
    "download": true

    /* Alternative : using a remote TTS
    "type": "remote",
    "url": "http://localhost:11111/tts",
    */
  },

  "lang-detector": {
    // Detects language in text to determine if translation is required.
    "type": "lingua",
    "source": ["french", "english"],
    "target": "french"
  },

  "translator": {
    // Tool used to translate text.
    // You can use an LLM, or argos the is lighter, but less accurate.
    "type": "llm",
    "model": "gemma4:e2b",
    "prompt": "Traduis le texte suivant vers le français., \
Le texte peut contenir des erreurs car il a été construit par un OCR. \
Rectifie ces erreurs si possible. \
Le texte traduit sera lu à l'utilisateur via omnivoice. \
Tu peux donc ajouter les tags suivants dans le texte généré afin d'indiquer à omnivoice comment le lire parmi \
[laughter], [sigh], [confirmation-en], [question-en], [question-ah], [question-oh], [question-ei], [question-yi], [surprise-ah], [surprise-oh], [surprise-wa], [surprise-yo], [dissatisfaction-hnn]. \
Les tags ne sont pas nécessaires, et ne doivent pas être traduits s'ils sont présents. La réponse ne doit contenir que la traduction, et rien d'autre. \
Voici le texte à traduire : ``` \
[TEXT] \
```",

    /* Alternative : argos configuration.
    "type": "argos",
    "source": "eng",
    "target": "fra",
    "model_path": "models/argos"
    */
  },

  "llm": {
    // The LLM configuration, used for chatting, and can be used for translation.
    "type": "ollama",
    "url": "http://localhost:11434",
    "model": "gemma4:e2b",
    "key": "",
    "system-prompt": "Tu es un assistant nommé Jean-Claude. \
Les questions qui te sont fournies proviennent de textes extraits par OCR ou via un outil de Speech-to-text, dont la qualité est parfois variable. \
Si le texte te semble incohérent, essaie de trouver comment le corriger. \
Réponds toujours à la dernière demande formulée, en t'appuyant si nécessaire sur les informations provenant de l'historique qui t'es fourni.",
    // Keeps history size controlled in case of per-token prices.
    "max-history": 5
  },

  "microphone": {
    // How user voice is captured.
    "sample-rate": 16000,
    "channels": 1,
    "dtype": "float32",
    "device": null,
    "blocksize": 1024
  },

  "stt": {
    // How user voice is converted to text.
    "type": "faster-whisper",
    "model": "small",
    "model_path": "models/faster-whisper",
    "device": "auto",
    "compute_type": "int8",
    "download": true

    /* Alternative : using a remote STT
    "type": "remote",
    "url": "http://localhost:11111/stt",
    */
  },

  "keybind": {
    // Binds keys to actions.
    "capture": {
      "key": "shift+f1",
      // Strict controls if we accept other keys typed in-between.
      "strict": true
    },
    "ask": {
      "key": "shift+f2",
      "strict": true
    }
  },

  "processing-overlay": {
    // Controls the display of the overlay showing bars.
    "width": 200,
    "height": 20,
    "bar_color": [255, 140, 33]
  },

  "expose": {
    // You can expose sevices to a computer to another if, like me, the computer you need this tool is unable to run
    // the OCR, speech-to-text or text-to-speech utilities in reasonable delays.
    "enabled": false,
    "host": "0.0.0.0",
    "port": "11111",

    "services": {
      "ocr": {
        "type": "easyocr",
        "download": false,
        "model_path": "models/easy_ocr",
        "langs": ["fr", "en"]
      },

      "stt": {
        "type": "faster-whisper",
        "model": "small",
        "model_path": "models/faster-whisper",
        "device": "auto",
        "compute_type": "int8",
        "download": false
      },

      "tts": {
        "type": "omnivoice",
        "model_path": "models/OmniVoice",
        "ref_voice_path": null,
        "ref_voice_text": null,
        "repo_id": "k2-fsa/OmniVoice",
        "device": "auto",
        "download": false
      }
    }
  }
}